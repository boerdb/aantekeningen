# Kopieer naar .env.local:
#   copy .env.example .env.local
#
# Next.js: lokaal of op je app-server (bijv. 192.168.1.32)
# MySQL:   DB-server (192.168.1.14) — database aantekeningen
# Zelfde patroon als med-track-pwa / dash-next-app

DATABASE_URL=mysql://aantekeningen:JOUW_DB_WACHTWOORD@192.168.1.14:3306/aantekeningen

# OCR: manual | mathpix | google
# Zonder API-keys: laat op manual (foto opslaan + zelf typen/corrigeren)
OCR_PROVIDER=manual

# Mathpix (beste voor formules + chemische diagrammen) — zie docs/OCR.md
# MATHPIX_APP_ID=
# MATHPIX_APP_KEY=

# Google Cloud Vision (goede algemene OCR, minder sterk op structuurformules)
# GOOGLE_VISION_API_KEY=

NODE_ENV=development
